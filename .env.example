# Kopyala: copy .env.example .env.local
#
# === Üretim özeti (Vercel): DEPLOY_RAILWAY_VERCEL.md ===

# ---------- AGENTS_JSON (Telegram bot ile BİREBİR aynı tek satır) ----------
# Vercel Environment: TEK SATIR; tırnak yok.
#
#   cd ../telegram-degen-bot && npm run agents:paste-file
# → AGENTS_JSON.paste.txt → Vercel AGENTS_JSON
#
# Railway: dosya kullanacaksan AGENTS_JSON yerine:
# AGENTS_JSON_PATH=/path/to/agents.local.json
#
# HL v2 trade: her agent için walletAddress (master) zorunlu.
# hlApiWalletKey JSON'da opsiyonel — tercih: aşağıdaki HL_API_WALLET_KEY_<SUFFIX>
# SUFFIX = alias küçük harf, @ ve harf dışı atılır, büyük harf (taxer-claw → TAXERCLAW).
# İsteğe bağlı: label, hlWallet, apiKey, forumApiKey
#
# AGENTS_JSON=[{"alias":"friday","apiKey":"acp-...","walletAddress":"0x...40hex","hlWallet":"0x..."}]
AGENTS_JSON=[]

# Tek secret ile çoklu agent (Vercel’de tek “Sensitive” değişken; eksik alanları doldurur):
# HL_TRADE_SECRETS_JSON={"pokedex":{"hlApiWalletKey":"0x...64hex","walletAddress":"0x...40hex","hlWallet":"0x...40hex"}}
# hlWallet / hlSubaccount opsiyonel (HL açık emir sorgusu için API cüzdan adresi).

# ---------- HL API wallet (çoklu agent; HL_API_WALLET_KEY_<SUFFIX>) ----------
# HL_API_WALLET_KEY_FRIDAY=0x...64hex
# HL_MASTER_ADDRESS_FRIDAY=0x...40hex
# HL_SUBACCOUNT_ADDRESS_FRIDAY=0x...40hex   (opsiyonel; AGENTS_JSON hlWallet ile aynı)
# HL_API_WALLET_KEY_ICHIMOKU=0x...
# İsteğe bağlı: AGENTS_JSON’daki eski hlWallet yerine HL API adresi (secrets/hl-api-wallets.env ile uyum):
# HL_API_WALLET_ADDRESS_TAXERCLAW=0x...40hex
# Tek agent yerel deneme: HL_API_WALLET_KEY=0x...  +  HL_MASTER_ADDRESS=0x...
# Tek agent HL subaccount: HL_SUBACCOUNT_ADDRESS=0x...

# ---------- HL ağı (bot ile aynı olmalı) ----------
# HYPERLIQUID_INFO_URL=https://api.hyperliquid.xyz/info
# HYPERLIQUID_INFO_URL=https://api.hyperliquid-testnet.xyz/info

# ---------- Panel ----------
DASHBOARD_PASSWORD=
DASHBOARD_SESSION_SECRET=

# ---------- Upstash (işlem geçmişi /api/activity — trade route'ları log yazar) ----------
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# İsteğe bağlı (forum autopost — trade aç/kapa SIGNALS)
# Tek global anahtar yeterliyse AGENTS_JSON’da her agent için forumApiKey şart değil:
# DGCLAW_API_KEY=dgc_...
# ACP_API_URL=https://claw-api.virtuals.io
# ACP_BUILDER_CODE=

# Eski pozisyon kapatma — Degen ACP v1 job (dashboard "Kapat (ACP v1)").
# Bearer: ilgili agent forumApiKey (dgc_…) = AGENTS_JSON forumApiKey
# DEGEN_ACP_API_BASE=https://api.agdp.io/degen-acp

# ---------- Base → HL perp_deposit (dashboard "Base'den HL'ye yatır") ----------
# A) Sunucuda doğrudan ACP (Railway’de tüm Next veya sadece worker):
# ACP_CLI_DIR=D:/super-saiyan-raichu/acp-cli-v2
#
# B) Vercel + ayrı worker (önerilen): Next tarafında sadece bunlar; worker’da da aynı secret + ACP_CLI_DIR
# ACP_PERP_DEPOSIT_PROXY_URL=https://xxx.up.railway.app
# ACP_PERP_DEPOSIT_PROXY_SECRET=uzun-rastgele-paylasilan-anahtar
#
# Worker başlat (degen-dashboard kökü): npm run perp-deposit-worker
# Worker ortamı: ACP_PERP_DEPOSIT_PROXY_SECRET, ACP_CLI_DIR, acp-cli-v2 + OAuth config.json
# (İsteğe bağlı port: PERP_DEPOSIT_WORKER_PORT=3847)
#
# İsteğe bağlı (varsayılan DegenClaw provider):
# ACP_PERP_DEPOSIT_PROVIDER=0xd478a8B40372db16cA8045F28C6FE07228F3781A
# ACP_PERP_DEPOSIT_CHAIN_ID=8453
