# Kopyala: cp .env.example .env.local  (Windows: copy .env.example .env.local)

# Telegram bot ile BİREBİR aynı agent listesi (tek satır JSON veya çok satırlı escape)
# Örnek dosya: ../telegram-degen-bot/agents.local.json — içeriği tek satıra indir veya Railway'de dosya yolu kullan
AGENTS_JSON=[]

# Panel girişi
DASHBOARD_PASSWORD=

# Oturum çerezi imzası — en az 32 karakter rastgele string
DASHBOARD_SESSION_SECRET=

# İsteğe bağlı (varsayılan claw-api)
# ACP_API_URL=https://claw-api.virtuals.io
# ACP_BUILDER_CODE=

# Redis (activity log vb. kullanıyorsan)
# REDIS_URL=
